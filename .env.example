# LLM Provider Configuration
# All agents use the OpenAI chat-completions protocol.
# Works with any compatible provider or local server.

# --- Cloud providers ---
# GitHub Models / Azure OpenAI:
OPENAI_API_KEY=your-key-here
MODEL_ID=gpt-4o
OPENAI_BASE_URL=https://models.inference.ai.azure.com

# OpenRouter (uncomment and replace above):
# OPENAI_API_KEY=sk-or-xxxxx
# MODEL_ID=openai/gpt-4o
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# --- Local servers (no cloud API required) ---
# LM Studio (http://localhost:1234/v1):
# OPENAI_API_KEY=lm-studio
# MODEL_ID=lmstudio-community/Qwen2.5-7B-Instruct-GGUF
# OPENAI_BASE_URL=http://localhost:1234/v1

# Ollama (http://localhost:11434/v1):
# OPENAI_API_KEY=ollama
# MODEL_ID=qwen2.5:7b
# OPENAI_BASE_URL=http://localhost:11434/v1

# GPT4All (http://localhost:4891/v1):
# OPENAI_API_KEY=gpt4all
# MODEL_ID=Mistral 7B Instruct
# OPENAI_BASE_URL=http://localhost:4891/v1

# Telegram (optional, for s04_channels.py)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF

# Feishu / Lark (optional, for s04_channels.py)
# FEISHU_APP_ID=cli_xxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxx
# FEISHU_DOMAIN=feishu    # "feishu" for domestic, "lark" for international

# Heartbeat (optional, for s07_heartbeat_cron.py)
# HEARTBEAT_INTERVAL=1800
# HEARTBEAT_ACTIVE_START=9
# HEARTBEAT_ACTIVE_END=22
